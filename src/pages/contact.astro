---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../../data/site.json';
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${siteData.name}. We'd love to hear your questions, suggestions, or feedback.`}
>
  <!-- Header -->
  <section class="container-narrow py-20 md:py-32">
    <span class="label-text text-secondary font-bold mb-6 block">Get in Touch</span>
    <h1 class="font-headline italic text-4xl md:text-5xl leading-tight tracking-tighter mb-8">Contact Us</h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed font-body">
      Have a question, suggestion, or want to work with us? Drop us a message and we'll get back to you as soon as we can.
    </p>
  </section>

  <!-- Form -->
  <section class="bg-surface-container-low py-16 md:py-24">
    <div class="container-narrow">
      <!-- TODO: Replace xplaceholder with a real Formspree form ID -->
      <form class="space-y-8" action="https://formspree.io/f/xplaceholder" method="POST">
        <div>
          <label for="name" class="label-text text-on-surface font-bold mb-3 block">Name *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-0 py-4 bg-transparent border-0 border-b-2 border-surface-container-highest text-on-surface font-body
                   focus:outline-none focus:border-secondary transition-colors placeholder:text-on-surface-variant/40"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="label-text text-on-surface font-bold mb-3 block">Email *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-0 py-4 bg-transparent border-0 border-b-2 border-surface-container-highest text-on-surface font-body
                   focus:outline-none focus:border-secondary transition-colors placeholder:text-on-surface-variant/40"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="subject" class="label-text text-on-surface font-bold mb-3 block">Subject</label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="w-full px-0 py-4 bg-transparent border-0 border-b-2 border-surface-container-highest text-on-surface font-body
                   focus:outline-none focus:border-secondary transition-colors placeholder:text-on-surface-variant/40"
            placeholder="What is this about?"
          />
        </div>

        <div>
          <label for="message" class="label-text text-on-surface font-bold mb-3 block">Message *</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="w-full px-0 py-4 bg-transparent border-0 border-b-2 border-surface-container-highest text-on-surface font-body
                   focus:outline-none focus:border-secondary transition-colors resize-y placeholder:text-on-surface-variant/40"
            placeholder="Your message..."
          ></textarea>
        </div>

        <button type="submit" class="btn-primary grain-overlay">
          Send Message
          <span class="material-symbols-outlined text-sm ml-3">send</span>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
