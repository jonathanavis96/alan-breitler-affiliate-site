---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex={true}>
  <div class="container-narrow py-32 md:py-48 text-center">
    <p class="font-headline italic text-[8rem] md:text-[12rem] leading-none text-surface-container-highest mb-4">404</p>
    <h1 class="font-headline italic text-3xl md:text-4xl text-on-surface mb-6">Page Not Found</h1>
    <p class="text-on-surface-variant font-body text-lg mb-12">
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="btn-primary no-underline">
        Go Home
        <span class="material-symbols-outlined text-sm ml-3">home</span>
      </a>
      <a href="/best/" class="btn-secondary no-underline">
        Browse Best Picks
      </a>
    </div>
  </div>
</BaseLayout>
