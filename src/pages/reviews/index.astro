---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteData from '../../../data/site.json';
import productData from '../../../data/products.json';
import { url } from '../../lib/base';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Reviews - ${siteData.name}`,
  description: 'In-depth, honest product reviews covering features, performance, and value.',
};

// Use products as review entries
const reviews = productData.products;
---

<BaseLayout
  title="Reviews"
  description="In-depth, honest product reviews covering features, performance, and value."
  schema={schema}
>
  <!-- Header -->
  <section class="container-wide py-20 md:py-32">
    <span class="label-text text-primary font-bold mb-6 block">In-Depth Analysis</span>
    <h1 class="font-headline font-bold text-5xl md:text-6xl leading-[0.9] tracking-tight max-w-3xl mb-8">Product Reviews</h1>
    <p class="text-muted text-lg max-w-xl leading-relaxed font-body">
      Detailed, honest reviews of individual products. We cover features, performance, value, and who each product is best for.
    </p>
  </section>

  <!-- Review listings -->
  <section class="bg-surface py-16 md:py-24">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((product) => (
          <a href={url(`/reviews/${product.slug}/`)} class="card group no-underline text-text">
            <div class="aspect-square bg-surface-alt rounded-lg mb-6 flex items-center justify-center p-4">
              <img
                src={url(product.image)}
                alt={product.name}
                class="max-w-full max-h-full object-contain group-hover:scale-105 transition-all duration-500"
                loading="lazy"
              />
            </div>

            <div class="flex items-center gap-3 mb-3">
              <span class="label-text text-primary font-bold">{product.brand}</span>
              <span class="label-text text-muted-dim">·</span>
              <span class="label-text text-muted-dim">{product.categories.map((c: string) => c.replaceAll('-', ' ')).join(', ')}</span>
            </div>

            <h3 class="font-headline font-bold text-xl mb-3">{product.name}</h3>

            <div class="flex items-center gap-2 mb-4">
              <span class={`font-headline font-bold text-sm ${product.overallScore >= 8.5 ? 'text-success' : product.overallScore >= 7 ? 'text-accent' : 'text-muted'}`}>
                {product.overallScore.toFixed(1)}/10
              </span>
              <span class="label-text text-muted-dim ml-auto">{product.pricing}</span>
            </div>

            <p class="text-muted text-sm font-body leading-relaxed line-clamp-2">{product.verdict}</p>

            <span class="inline-flex items-center gap-2 mt-4 text-primary label-text font-bold group-hover:gap-3 transition-all">
              Read full review
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
