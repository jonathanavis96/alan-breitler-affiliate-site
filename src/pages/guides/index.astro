---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import siteData from '../../../data/site.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Buying Guides - ${siteData.name}`,
  description: 'Expert buying guides to help you understand what to look for before you buy.',
};
---

<BaseLayout
  title="Buying Guides"
  description="Expert buying guides to help you understand what to look for before making a purchase."
  schema={schema}
>
  <Section>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">Buying Guides</h1>
    <p class="text-lg text-gray-600 mb-10 max-w-2xl">
      Not sure what to look for? Our buying guides break down the key factors so you can make a confident decision.
    </p>

    <!-- Placeholder: Guide listings will go here -->
    <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl p-12 text-center">
      <p class="text-gray-500 text-lg mb-2">Content coming soon</p>
      <p class="text-gray-400 text-sm">Our expert buying guides will be published here once the product categories are finalised.</p>
    </div>
  </Section>
</BaseLayout>
