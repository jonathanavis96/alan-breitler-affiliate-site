---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteData from '../../../data/site.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Buying Guides - ${siteData.name}`,
  description: 'Expert buying guides to help you understand what to look for before you buy.',
};
---

<BaseLayout
  title="Buying Guides"
  description="Expert buying guides to help you understand what to look for before making a purchase."
  schema={schema}
>
  <section class="container-wide py-20 md:py-32">
    <span class="label-text text-secondary font-bold mb-6 block">Smart Decisions</span>
    <h1 class="font-headline italic text-5xl md:text-6xl leading-[0.9] tracking-tighter max-w-3xl mb-8">Buying Guides</h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed font-body mb-16">
      Not sure what to look for? Our buying guides break down the key factors so you can make a confident decision.
    </p>

    <!-- Placeholder -->
    <div class="bg-surface-container-low p-16 text-center">
      <span class="material-symbols-outlined text-5xl text-on-surface-variant/20 mb-6">auto_stories</span>
      <p class="text-on-surface-variant font-body text-lg mb-2">Content coming soon</p>
      <p class="text-on-surface-variant/60 font-body text-sm">Our expert buying guides will be published here once the product categories are finalised.</p>
    </div>
  </section>
</BaseLayout>
