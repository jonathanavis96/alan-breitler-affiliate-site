---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteData from '../../../data/site.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Best Picks - ${siteData.name}`,
  description: 'Curated lists of the best products in each category, researched and compared.',
};
---

<BaseLayout
  title="Best Picks"
  description="Curated lists of the best products in each category, researched and compared by our team."
  schema={schema}
>
  <section class="container-wide py-20 md:py-32">
    <span class="label-text text-secondary font-bold mb-6 block">Editor's Choice</span>
    <h1 class="font-headline italic text-5xl md:text-6xl leading-[0.9] tracking-tighter max-w-3xl mb-8">Best Picks 2026</h1>
    <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed font-body mb-16">
      Our curated lists of the best products in each category. Every pick is researched, compared, and chosen based on real performance and value.
    </p>

    <!-- Placeholder -->
    <div class="bg-surface-container-low p-16 text-center">
      <span class="material-symbols-outlined text-5xl text-on-surface-variant/20 mb-6">stars</span>
      <p class="text-on-surface-variant font-body text-lg mb-2">Content coming soon</p>
      <p class="text-on-surface-variant/60 font-body text-sm">Our expert roundups and "best of" lists will be published here once the product categories are finalised.</p>
    </div>
  </section>
</BaseLayout>
