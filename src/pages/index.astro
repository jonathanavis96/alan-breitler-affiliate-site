---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import CategoryCard from '../components/CategoryCard.astro';
import siteData from '../../data/site.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteData.name,
  url: siteData.url,
  description: siteData.description,
};
---

<BaseLayout title="Home" schema={schema}>
  <!-- Hero -->
  <Hero
    title="Find the Best Products for Your Needs"
    subtitle="We research, compare, and review so you don't have to. Honest recommendations backed by real analysis."
    ctaText="Browse Our Top Picks"
    ctaHref="/best/"
    trustLine="Trusted by readers who value honest, well-researched recommendations"
  />

  <!-- Categories / Content Pillars -->
  <Section
    title="What Are You Looking For?"
    subtitle="Explore our categories to find expert reviews and buying guides."
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <CategoryCard
        title="Best Picks"
        description="Curated lists of the top products in each category, tested and compared."
        href="/best/"
        icon="🏆"
      />
      <CategoryCard
        title="In-Depth Reviews"
        description="Detailed, honest reviews covering features, performance, and value."
        href="/reviews/"
        icon="🔍"
      />
      <CategoryCard
        title="Buying Guides"
        description="Learn what to look for before you buy with our expert buying guides."
        href="/guides/"
        icon="📖"
      />
    </div>
  </Section>

  <!-- How We Work -->
  <Section
    title="Why Trust Our Recommendations?"
    subtitle="We follow a rigorous process to ensure every recommendation earns its place."
    class="bg-gray-50"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-12 h-12 bg-blue-100 text-primary rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">We Research</h3>
        <p class="text-sm text-gray-600">We dig into specifications, user feedback, and expert opinions for every product we cover.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-green-100 text-secondary rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">We Compare</h3>
        <p class="text-sm text-gray-600">We put products side by side, evaluating performance, value, and real-world usability.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-amber-100 text-accent rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">We Recommend</h3>
        <p class="text-sm text-gray-600">We only recommend products we genuinely believe in, with honest pros and cons.</p>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section class="text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Ready to Find Your Perfect Match?</h2>
      <p class="text-gray-600 mb-6">Browse our latest reviews and buying guides to make confident purchasing decisions.</p>
      <a href="/best/" class="btn-primary no-underline">
        See Our Top Picks
      </a>
    </div>
  </Section>
</BaseLayout>
