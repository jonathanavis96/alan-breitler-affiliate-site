---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import siteData from '../../data/site.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteData.name,
  url: siteData.url,
  description: siteData.description,
};
---

<BaseLayout title="Home" schema={schema}>
  <!-- Hero: Anti-Grid Layout -->
  <Hero
    eyebrow="2026 Editorial Outlook"
    title="The Search for the Best Ends Here."
    highlightWord="Best"
    subtitle="We dismantle market hype with rigorous testing and obsessive manual reviews. Discover the definitive list of products that deliver on their promises."
    ctaText="Discover Our 2026 Best Picks"
    ctaHref="/best/"
    secondaryCtaText="View Editorial Standards"
    secondaryCtaHref="/about/"
    heroImage="/images/hero-placeholder.svg"
    heroImageAlt="Abstract editorial product photography"
    overlayLabel="Currently Testing"
    overlayTitle="The Silicon Frontier: Next-Gen Acoustics"
  />

  <!-- Bento Box Grid: Content Discovery -->
  <section class="container-wide mt-40">
    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-xl">
        <h2 class="font-headline italic text-4xl mb-4">Navigating the Noise</h2>
        <p class="text-on-surface-variant font-body">Our hierarchy of insight, designed for the conscious consumer who values precision over volume.</p>
      </div>
      <div class="h-[1px] flex-grow bg-surface-container-highest mx-8 hidden md:block"></div>
      <span class="label-text opacity-50">Exploration Core</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 h-auto md:h-[600px]">
      <!-- Big Feature: Best Picks -->
      <a href="/best/" class="md:col-span-2 md:row-span-2 bg-surface-container-low p-10 flex flex-col justify-between relative overflow-hidden group no-underline text-on-surface">
        <div class="z-20">
          <span class="badge-editorial mb-6">Editor's Choice</span>
          <h3 class="font-headline italic text-4xl leading-tight">Best Picks 2026</h3>
          <p class="mt-4 text-on-surface-variant max-w-xs font-body">The top 1% of products that survived our stress tests this year.</p>
        </div>
        <div class="flex justify-between items-end z-20">
          <span class="text-secondary font-label uppercase text-xs tracking-widest font-bold border-b-2 border-secondary pb-1 group-hover:pr-4 transition-all">Explore the list</span>
          <span class="material-symbols-outlined text-6xl opacity-10">stars</span>
        </div>
      </a>

      <!-- Medium Feature: In-Depth Reviews -->
      <a href="/reviews/" class="md:col-span-2 bg-primary text-on-primary p-8 flex flex-col justify-between grain-overlay no-underline">
        <div>
          <h3 class="font-headline italic text-3xl text-on-primary">In-Depth Reviews</h3>
          <p class="text-primary-fixed-dim text-sm mt-2 font-body">Comprehensive technical analysis for every product we cover.</p>
        </div>
        <div class="flex justify-between items-center z-20">
          <span class="label-text text-primary-fixed-dim">Read our latest</span>
          <span class="material-symbols-outlined text-on-primary">menu_book</span>
        </div>
      </a>

      <!-- Small Feature: Buying Guides -->
      <a href="/guides/" class="md:col-span-1 bg-secondary text-on-secondary p-8 flex flex-col justify-between no-underline">
        <span class="material-symbols-outlined text-3xl text-on-secondary">auto_stories</span>
        <div>
          <h3 class="font-label uppercase font-bold text-xs tracking-widest text-on-secondary not-italic">Buying Guides</h3>
          <p class="text-xs opacity-80 mt-1 font-body">Smart checklists for the final decision.</p>
        </div>
      </a>

      <!-- Small Feature: How We Test -->
      <a href="/about/" class="md:col-span-1 bg-surface-container-highest p-8 flex flex-col justify-between border-l-4 border-on-tertiary-container no-underline text-on-surface">
        <span class="material-symbols-outlined text-3xl text-on-tertiary-container">biotech</span>
        <div>
          <h3 class="font-label uppercase font-bold text-xs tracking-widest text-on-surface not-italic">How We Test</h3>
          <p class="text-xs text-on-surface-variant mt-1 font-body">The science of objectivity.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Trust Section: How We Test -->
  <section class="mt-40 bg-surface-container-low grain-overlay relative">
    <div class="container-wide py-12 md:py-24">
      <div class="max-w-4xl mx-auto text-center mb-20">
        <span class="label-text text-secondary font-bold mb-4 block">Our Methodology</span>
        <h2 class="font-headline italic text-5xl md:text-6xl mb-6">Built on Radical Transparency.</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed font-body">Most sites read the box. We break the product. Every recommendation is backed by practical stress-testing and empirical measurement.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative z-10">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-surface flex items-center justify-center mb-6 shadow-sm">
            <span class="material-symbols-outlined text-secondary">science</span>
          </div>
          <h4 class="font-headline italic text-2xl mb-3">Rigorous Benchmarking</h4>
          <p class="text-sm text-on-surface-variant leading-relaxed font-body">We use precision instruments and standardized tests to measure real performance, not marketing claims.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-surface flex items-center justify-center mb-6 shadow-sm">
            <span class="material-symbols-outlined text-secondary">psychology_alt</span>
          </div>
          <h4 class="font-headline italic text-2xl mb-3">Expert Blind Tests</h4>
          <p class="text-sm text-on-surface-variant leading-relaxed font-body">Multi-user blind panels eliminate brand bias to find what actually performs in everyday use.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-surface flex items-center justify-center mb-6 shadow-sm">
            <span class="material-symbols-outlined text-secondary">history_edu</span>
          </div>
          <h4 class="font-headline italic text-2xl mb-3">The Unfiltered Report</h4>
          <p class="text-sm text-on-surface-variant leading-relaxed font-body">We publish the full picture — pros, cons, and failures. No manufacturer editing allowed.</p>
        </div>
      </div>

      <div class="mt-20 flex justify-center">
        <div class="px-6 py-4 glass-panel inline-flex items-center gap-4">
          <div class="flex gap-1">
            <div class="w-2 h-2 bg-secondary animate-pulse"></div>
            <div class="w-2 h-2 bg-secondary opacity-50"></div>
            <div class="w-2 h-2 bg-secondary opacity-25"></div>
          </div>
          <p class="label-text font-bold">Live Lab Status: Testing New Products Weekly</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wide mt-40 mb-20">
    <div class="bg-primary text-on-primary p-12 md:p-20 relative overflow-hidden grain-overlay">
      <div class="relative z-20 max-w-2xl">
        <h2 class="font-headline italic text-5xl mb-8 text-on-primary">Ready to end the search?</h2>
        <p class="text-primary-fixed-dim mb-12 text-lg font-body">Browse by category or dive into our latest reviews. We've done the heavy lifting so you don't have to.</p>
        <div class="flex flex-wrap gap-4">
          <a href="/best/" class="inline-flex items-center gap-3 bg-secondary text-on-secondary px-10 py-5 font-label uppercase text-xs tracking-widest font-bold hover:bg-secondary-container transition-colors duration-300 no-underline">
            Browse Best Picks
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
          <a href="/reviews/" class="inline-flex items-center gap-3 bg-on-primary/10 text-on-primary px-10 py-5 font-label uppercase text-xs tracking-widest font-bold hover:bg-on-primary/20 transition-colors no-underline">
            Latest Reviews
          </a>
        </div>
        <div class="mt-12 flex flex-wrap gap-4">
          <span class="label-text opacity-40">Trending:</span>
          <a class="label-text hover:text-secondary underline decoration-secondary underline-offset-4 text-primary-fixed-dim" href="/best/">Mechanical Keyboards</a>
          <a class="label-text hover:text-secondary underline decoration-secondary underline-offset-4 text-primary-fixed-dim" href="/best/">Espresso Machines</a>
          <a class="label-text hover:text-secondary underline decoration-secondary underline-offset-4 text-primary-fixed-dim" href="/best/">Studio Monitors</a>
        </div>
      </div>
      <!-- Abstract gradient BG -->
      <div class="absolute right-0 top-0 h-full w-1/2 opacity-30 pointer-events-none">
        <div class="w-full h-full bg-gradient-to-br from-secondary/50 to-transparent"></div>
      </div>
    </div>
  </section>
</BaseLayout>
