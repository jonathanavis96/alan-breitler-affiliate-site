---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import GradientOrbs from '../components/GradientOrbs.astro';
import siteData from '../../data/site.json';
import { url } from '../lib/base';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  schema?: object;
  noindex?: boolean;
}

const {
  title,
  description = siteData.description,
  ogImage = url('/images/og-default.png'),
  ogType = 'website',
  canonicalUrl,
  schema,
  noindex = false,
} = Astro.props;

const fullTitle = title === 'Home'
  ? `${siteData.name} - ${siteData.tagline}`
  : `${title} | ${siteData.name}`;

const canonical = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, siteData.url).href} />
  <meta property="og:site_name" content={siteData.name} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, siteData.url).href} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

  <!-- Fonts: Space Grotesk (headings), IBM Plex Sans (body) — self-hosted -->
  <link rel="preload" href={url('/fonts/space-grotesk/space-grotesk-700.woff2')} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={url('/fonts/ibm-plex-sans/ibm-plex-sans-400.woff2')} as="font" type="font/woff2" crossorigin />
  <style set:html={`
    @font-face { font-family: 'Space Grotesk'; src: url('${url('/fonts/space-grotesk/space-grotesk-400.woff2')}') format('woff2'), url('${url('/fonts/space-grotesk/space-grotesk-400.woff')}') format('woff'); font-weight: 400; font-style: normal; font-display: swap; }
    @font-face { font-family: 'Space Grotesk'; src: url('${url('/fonts/space-grotesk/space-grotesk-500.woff2')}') format('woff2'), url('${url('/fonts/space-grotesk/space-grotesk-500.woff')}') format('woff'); font-weight: 500; font-style: normal; font-display: swap; }
    @font-face { font-family: 'Space Grotesk'; src: url('${url('/fonts/space-grotesk/space-grotesk-600.woff2')}') format('woff2'), url('${url('/fonts/space-grotesk/space-grotesk-600.woff')}') format('woff'); font-weight: 600; font-style: normal; font-display: swap; }
    @font-face { font-family: 'Space Grotesk'; src: url('${url('/fonts/space-grotesk/space-grotesk-700.woff2')}') format('woff2'), url('${url('/fonts/space-grotesk/space-grotesk-700.woff')}') format('woff'); font-weight: 700; font-style: normal; font-display: swap; }
    @font-face { font-family: 'IBM Plex Sans'; src: url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-400.woff2')}') format('woff2'), url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-400.woff')}') format('woff'); font-weight: 400; font-style: normal; font-display: swap; }
    @font-face { font-family: 'IBM Plex Sans'; src: url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-500.woff2')}') format('woff2'), url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-500.woff')}') format('woff'); font-weight: 500; font-style: normal; font-display: swap; }
    @font-face { font-family: 'IBM Plex Sans'; src: url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-600.woff2')}') format('woff2'), url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-600.woff')}') format('woff'); font-weight: 600; font-style: normal; font-display: swap; }
    @font-face { font-family: 'IBM Plex Sans'; src: url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-700.woff2')}') format('woff2'), url('${url('/fonts/ibm-plex-sans/ibm-plex-sans-700.woff')}') format('woff'); font-weight: 700; font-style: normal; font-display: swap; }
  `} />

  <!-- Material Symbols (icons) -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@0.577.0/dist/umd/lucide.min.js" defer></script>

  <!-- Schema markup -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="bg-background text-on-surface font-body">
  <Header />
  <SearchOverlay />
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }

      // Scroll-reveal: animate elements into view (supports all variants)
      const revealSelectors = '.scroll-reveal, .scroll-reveal-left, .scroll-reveal-right, .scroll-reveal-scale, .scroll-reveal-blur, .scroll-reveal-fade';
      const reveals = document.querySelectorAll(revealSelectors);
      if (reveals.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
        );
        reveals.forEach((el) => observer.observe(el));
      }
    });
  </script>
  <main class="flex-1 relative">
    <!-- Page-level ambient gradient orbs -->
    <GradientOrbs variant="page" />
    <slot />
  </main>
  <Footer />
</body>
</html>
