---
import GradientOrbs from './GradientOrbs.astro';
import { url } from '../lib/base';

interface Props {
  eyebrow?: string;
  title: string;
  rotatingWords?: string[];
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  eyebrow = 'Academic AI Intelligence',
  title = 'Find the Right AI Tools for',
  rotatingWords = ['Research', 'Writing', 'Analysis', 'Discovery'],
  subtitle = 'We rigorously evaluate AI tools so academics don\'t have to. Unbiased reviews, head-to-head comparisons, and scoring built for scholarly workflows.',
  ctaText = 'Explore Top Tools',
  ctaHref = url('/top-tools/'),
  secondaryCtaText = 'Join the Newsletter',
  secondaryCtaHref = '#newsletter',
} = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden grain-overlay">
  <!-- Decorative gradient blur orbs -->
  <GradientOrbs variant="hero" />
  <!-- Grid lines decoration -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true" style="background-image: linear-gradient(rgba(0,207,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(0,207,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="container-wide relative z-20 py-20 md:py-32">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      {eyebrow && (
        <div class="flex items-center gap-3 mb-8 animate-fade-in">
          <span class="inline-block w-8 h-[2px] bg-primary"></span>
          <span class="font-label text-[11px] uppercase tracking-[0.25em] text-primary font-semibold">{eyebrow}</span>
        </div>
      )}

      <!-- Main headline with typewriter -->
      <h1 class="font-headline font-bold text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-text mb-8 animate-fade-in animation-delay-100">
        {title}{' '}
        <span class="block mt-2">
          <span class="text-primary" id="hero-rotating-word">{rotatingWords[0]}</span><span id="hero-cursor" class="hero-cursor"></span><span class="text-accent">.</span>
        </span>
      </h1>

      <!-- Subtitle -->
      {subtitle && (
        <p class="text-muted text-lg md:text-xl max-w-2xl leading-relaxed font-body mb-12 animate-fade-in animation-delay-200">
          {subtitle}
        </p>
      )}

      <!-- Split CTA -->
      <div class="flex flex-wrap gap-4 animate-fade-in animation-delay-300">
        <a href={ctaHref} class="btn-primary no-underline">
          {ctaText}
          <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href={secondaryCtaHref} class="btn-secondary no-underline">
          {secondaryCtaText}
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-16 flex flex-wrap items-center gap-6 animate-fade-in animation-delay-400">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-success animate-pulse"></div>
          <span class="text-muted text-sm font-body">Updated weekly</span>
        </div>
        <span class="text-outline-variant hidden sm:inline">|</span>
        <span class="text-muted text-sm font-body">50+ AI tools reviewed</span>
        <span class="text-outline-variant hidden sm:inline">|</span>
        <span class="text-muted text-sm font-body">Built for academics</span>
      </div>
    </div>
  </div>
</section>

<!-- Typewriter script -->
<script define:vars={{ rotatingWords }}>
  window.__HERO_WORDS__ = rotatingWords;
</script>

<script>
  const el = document.getElementById('hero-rotating-word');
  const cursor = document.getElementById('hero-cursor');
  const words = (window as any).__HERO_WORDS__ || ['Research'];

  if (el && cursor && words.length > 1) {
    const TYPE_SPEED = 80;
    const DELETE_SPEED = 50;
    const PAUSE_AFTER_TYPE = 2200;
    const PAUSE_AFTER_DELETE = 400;
    let current = 0;

    function sleep(ms: number) {
      return new Promise(r => setTimeout(r, ms));
    }

    async function typeWord(word: string) {
      cursor!.classList.add('visible');
      for (let i = 0; i <= word.length; i++) {
        el!.textContent = word.slice(0, i);
        await sleep(TYPE_SPEED);
      }
      await sleep(200);
      cursor!.classList.remove('visible');
    }

    async function deleteWord(word: string) {
      cursor!.classList.add('visible');
      for (let i = word.length; i >= 0; i--) {
        el!.textContent = word.slice(0, i);
        await sleep(DELETE_SPEED);
      }
    }

    async function loop() {
      while (true) {
        const word = words[current];
        await typeWord(word);
        await sleep(PAUSE_AFTER_TYPE);
        await deleteWord(word);
        await sleep(PAUSE_AFTER_DELETE);
        current = (current + 1) % words.length;
      }
    }

    // Start after initial word is visible
    sleep(2000).then(async () => {
      await deleteWord(words[0]);
      await sleep(PAUSE_AFTER_DELETE);
      current = 1;
      loop();
    });
  }
</script>
