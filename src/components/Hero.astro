---
interface Props {
  eyebrow?: string;
  title: string;
  highlightWords?: string[];
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  heroImage?: string;
  heroImageAlt?: string;
  overlayLabel?: string;
  overlayTitle?: string;
}

const {
  eyebrow,
  title,
  highlightWords = ['Best'],
  subtitle,
  ctaText = 'Discover Our Best Picks',
  ctaHref = '/best/',
  secondaryCtaText,
  secondaryCtaHref,
  heroImage = '/images/hero-placeholder.svg',
  heroImageAlt = 'Featured editorial image',
  overlayLabel,
  overlayTitle,
} = Astro.props;

// Split title at the first highlight word placeholder
const firstWord = highlightWords[0];
const idx = title.indexOf(firstWord);
const before = idx >= 0 ? title.slice(0, idx) : title;
const after = idx >= 0 ? title.slice(idx + firstWord.length) : '';
---

<section class="relative min-h-[700px] flex flex-col md:flex-row items-center gap-12 py-20 overflow-visible grain-overlay container-wide">
  <!-- Text Content -->
  <div class="w-full md:w-3/5 z-20">
    {eyebrow && (
      <span class="badge-outlook mb-8 tracking-[0.2em] animate-fade-in">
        {eyebrow}
      </span>
    )}

    <h1 class="font-headline italic font-extrabold text-5xl md:text-8xl leading-[0.9] tracking-tighter mb-8 animate-fade-in animation-delay-100">
      The Search for the <span class="text-secondary border-r-[3px] border-secondary" id="hero-rotating-word">{firstWord}</span> Ends Here.
    </h1>

    {subtitle && (
      <p class="text-on-surface-variant text-lg md:text-xl max-w-lg mb-10 leading-relaxed font-body animate-fade-in animation-delay-200">
        {subtitle}
      </p>
    )}

    <div class="flex flex-wrap gap-4 animate-fade-in animation-delay-300">
      <a href={ctaHref} class="btn-primary grain-overlay no-underline">
        {ctaText}
        <span class="material-symbols-outlined text-sm ml-3">arrow_forward</span>
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="btn-secondary no-underline">
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>

  <!-- Hero Image -->
  <div class="w-full md:w-2/5 relative flex justify-end animate-fade-in animation-delay-200">
    <div class="relative w-full aspect-[4/5] bg-surface-container-high overflow-hidden shadow-2xl anti-grid-offset z-10">
      <img
        class="w-full h-full object-cover grayscale contrast-125 hover:grayscale-0 transition-all duration-1000"
        src={heroImage}
        alt={heroImageAlt}
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>

      {(overlayLabel || overlayTitle) && (
        <div class="absolute bottom-6 left-6 right-6 p-6 glass-panel border-l-2 border-secondary animate-slide-up animation-delay-500">
          {overlayLabel && (
            <p class="label-text mb-1 opacity-70">{overlayLabel}</p>
          )}
          {overlayTitle && (
            <p class="font-headline italic text-xl">{overlayTitle}</p>
          )}
        </div>
      )}
    </div>

    <!-- Asymmetric decorative blur -->
    <div class="absolute top-[-10%] right-[-10%] w-64 h-64 bg-secondary/10 rounded-full blur-[100px] -z-10 animate-pulse-slow"></div>
  </div>
</section>

<!-- Typewriter script -->
<script define:vars={{ highlightWords }}>
  window.__HERO_WORDS__ = highlightWords;
</script>

<script>
  const el = document.getElementById('hero-rotating-word');
  const words = (window as any).__HERO_WORDS__ || ['Best'];

  if (el && words.length > 1) {
    const TYPE_SPEED = 80;
    const DELETE_SPEED = 50;
    const PAUSE_AFTER_TYPE = 2000;
    const PAUSE_AFTER_DELETE = 300;
    let current = 0;

    function sleep(ms: number) {
      return new Promise(r => setTimeout(r, ms));
    }

    async function typeWord(word: string) {
      for (let i = 0; i <= word.length; i++) {
        el!.textContent = word.slice(0, i);
        await sleep(TYPE_SPEED);
      }
    }

    async function deleteWord(word: string) {
      for (let i = word.length; i >= 0; i--) {
        el!.textContent = word.slice(0, i);
        await sleep(DELETE_SPEED);
      }
    }

    async function loop() {
      while (true) {
        const word = words[current];
        await typeWord(word);
        await sleep(PAUSE_AFTER_TYPE);
        await deleteWord(word);
        await sleep(PAUSE_AFTER_DELETE);
        current = (current + 1) % words.length;
      }
    }

    // Start after initial word is visible for a moment
    sleep(1500).then(async () => {
      await deleteWord(words[0]);
      await sleep(PAUSE_AFTER_DELETE);
      current = 1;
      loop();
    });
  }
</script>
