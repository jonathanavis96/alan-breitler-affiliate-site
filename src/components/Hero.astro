---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  trustLine?: string;
}

const {
  title,
  subtitle,
  ctaText = 'Explore Our Picks',
  ctaHref = '/best/',
  trustLine,
} = Astro.props;
---

<section class="relative bg-gradient-to-br from-gray-50 to-blue-50 py-16 md:py-24">
  <div class="container-wide text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 max-w-4xl mx-auto leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-8">
        {subtitle}
      </p>
    )}
    <a href={ctaHref} class="btn-primary text-base no-underline">
      {ctaText}
      <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
    {trustLine && (
      <p class="mt-6 text-sm text-gray-500">{trustLine}</p>
    )}
  </div>
</section>
