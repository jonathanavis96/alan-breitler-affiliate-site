---
import siteData from '../../data/site.json';
import { url } from '../lib/base';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 bg-background/90 backdrop-blur-md">
  <div class="container-wide flex justify-between items-center py-4">
    <!-- Logo -->
    <div class="flex items-center gap-4">
      <button
        type="button"
        class="md:hidden text-primary active:scale-95 duration-200 hover:opacity-70 transition-opacity"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-menu-button"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
      <a href={url('/')} class="text-2xl font-headline font-black uppercase italic tracking-tight text-primary no-underline hover:opacity-70 transition-opacity">
        {siteData.name}
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8" aria-label="Main navigation">
      {siteData.navigation.map((item) => {
        const href = url(item.href);
        return (
          <a
            href={href}
            class:list={[
              'label-text no-underline transition-opacity',
              currentPath === href || (href !== url('/') && currentPath.startsWith(href))
                ? 'text-secondary font-bold'
                : 'text-on-surface-variant hover:opacity-70',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Search -->
    <div class="flex items-center gap-4">
      <button id="search-open" class="text-primary active:scale-95 duration-200 hover:opacity-70 transition-opacity" aria-label="Search">
        <span class="material-symbols-outlined">search</span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="hidden md:hidden bg-background" id="mobile-menu">
    <nav class="container-wide py-4 flex flex-col gap-4">
      {siteData.navigation.map((item) => {
        const href = url(item.href);
        return (
          <a
            href={href}
            class:list={[
              'label-text no-underline py-2',
              currentPath === href || (href !== url('/') && currentPath.startsWith(href))
                ? 'text-secondary font-bold'
                : 'text-on-surface-variant',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    button?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
