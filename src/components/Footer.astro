---
import siteData from '../../data/site.json';
import { url } from '../lib/base';

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-surface border-t border-outline/30 pt-16 pb-8">
  <!-- Subtle grain overlay -->
  <div class="grain-overlay pointer-events-none absolute inset-0 z-0"></div>

  <div class="container-wide relative z-10">
    <!-- Top section: Newsletter + Nav columns -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-12">

      <!-- Newsletter Signup Placeholder -->
      <div class="md:col-span-5">
        <h3 class="font-headline text-xl font-bold tracking-tight text-text mb-2">
          Stay ahead of the curve
        </h3>
        <p class="text-muted text-sm mb-5 max-w-sm">
          Get weekly AI tool picks, academic workflow tips, and exclusive reviews — straight to your inbox.
        </p>
        <form class="flex gap-2" onsubmit="return false;" aria-label="Newsletter signup">
          <input
            type="email"
            placeholder="your@university.edu"
            class="flex-1 px-4 py-2.5 rounded-lg bg-surface-alt border border-outline text-text text-sm placeholder:text-muted-dim focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/40 transition-colors"
            aria-label="Email address"
            disabled
          />
          <button
            type="submit"
            class="px-5 py-2.5 rounded-lg bg-primary text-on-primary font-body text-sm font-semibold hover:bg-primary-hover transition-colors whitespace-nowrap cursor-not-allowed opacity-90"
            disabled
            title="Coming soon"
          >
            Subscribe
          </button>
        </form>
        <p class="text-muted-dim text-xs mt-2">No spam. Unsubscribe anytime. Coming soon.</p>
      </div>

      <!-- Nav Links -->
      <div class="md:col-span-3 md:col-start-7">
        <h4 class="font-headline text-sm font-semibold tracking-wide uppercase text-muted mb-4">Explore</h4>
        <nav class="flex flex-col gap-2.5" aria-label="Footer explore navigation">
          {siteData.navigation.map((item) => (
            <a
              href={url(item.href)}
              class="text-sm text-muted hover:text-primary transition-colors no-underline"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Legal Links -->
      <div class="md:col-span-3">
        <h4 class="font-headline text-sm font-semibold tracking-wide uppercase text-muted mb-4">Legal</h4>
        <nav class="flex flex-col gap-2.5" aria-label="Footer legal navigation">
          {siteData.footer.links.map((link) => (
            <a
              href={url(link.href)}
              class="text-sm text-muted hover:text-primary transition-colors no-underline"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-outline/40 mb-8"></div>

    <!-- Bottom bar: Brand + Copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Brand mark -->
      <a href={url('/')} class="font-headline text-2xl font-bold tracking-tight no-underline hover:opacity-80 transition-opacity">
        <span class="text-primary">{siteData.brandPrefix}</span><span class="text-text">{siteData.brandSuffix}</span>
      </a>

      <!-- Copyright + tagline -->
      <p class="text-muted-dim text-xs text-center sm:text-right">
        &copy; {currentYear} {siteData.name}. All rights reserved.
        <span class="hidden sm:inline">&mdash;</span>
        <br class="sm:hidden" />
        <span class="text-muted">{siteData.tagline}</span>
      </p>
    </div>
  </div>
</footer>

<!-- Mobile Bottom Nav -->
<nav class="md:hidden fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-2 bg-base/80 backdrop-blur-xl shadow-[0_-4px_20px_rgba(0,0,0,0.3)] z-50 border-t border-outline/20" aria-label="Mobile navigation">
  <a href={url('/')} class="flex flex-col items-center justify-center text-primary pt-2 active:scale-90 transition-transform no-underline">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" /></svg>
    <span class="font-label text-[10px] uppercase tracking-widest font-bold">Home</span>
  </a>
  <a href={url('/top-tools/')} class="flex flex-col items-center justify-center text-muted hover:text-primary pt-2 active:scale-90 transition-transform no-underline">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
    <span class="font-label text-[10px] uppercase tracking-widest font-bold">Top Tools</span>
  </a>
  <button type="button" id="mobile-search-trigger" class="flex flex-col items-center justify-center text-muted hover:text-primary pt-2 active:scale-90 transition-transform bg-transparent border-none cursor-pointer">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
    <span class="font-label text-[10px] uppercase tracking-widest font-bold text-current">Search</span>
  </button>
  <a href={url('/resources/')} class="flex flex-col items-center justify-center text-muted hover:text-primary pt-2 active:scale-90 transition-transform no-underline">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
    <span class="font-label text-[10px] uppercase tracking-widest font-bold">Resources</span>
  </a>
</nav>

<script>
  document.getElementById('mobile-search-trigger')?.addEventListener('click', () => {
    document.getElementById('search-open')?.click();
  });
</script>
