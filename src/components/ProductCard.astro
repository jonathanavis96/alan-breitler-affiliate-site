---
interface Props {
  name: string;
  slug?: string;
  image?: string;
  rating: number;
  price?: string;
  pros?: string[];
  cons?: string[];
  verdict?: string;
  affiliateSlug: string;
  badge?: string;
}

const {
  name,
  slug,
  image = '/images/products/placeholder.jpg',
  rating,
  price,
  pros = [],
  cons = [],
  verdict,
  affiliateSlug,
  badge,
} = Astro.props;

const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
---

<div class="bg-surface relative overflow-hidden group hover:bg-surface-container-low transition-colors duration-300">
  {badge && (
    <div class="absolute top-0 right-0 z-10">
      <span class:list={[
        'badge',
        badge === "Editor's Choice" ? 'badge-editorial' : 'bg-secondary text-on-secondary',
      ]}>
        {badge}
      </span>
    </div>
  )}

  <div class="flex flex-col sm:flex-row">
    <!-- Product Image -->
    <div class="sm:w-56 flex-shrink-0 bg-white flex items-center justify-center p-4">
      <img
        src={image}
        alt={name}
        class="max-w-full max-h-full object-contain grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out"
        loading="lazy"
      />
    </div>

    <!-- Product Info -->
    <div class="flex-1 min-w-0 p-8">
      <h3 class="font-headline italic text-xl mb-3">{name}</h3>

      <!-- Rating + Price -->
      <div class="flex items-center gap-3 mb-4">
        <div class="flex gap-0.5" aria-label={`Rating: ${rating} out of 5`}>
          {Array.from({ length: 5 }, (_, i) => (
            <span class={`text-xs ${i < fullStars ? 'text-on-tertiary-container' : (i === fullStars && hasHalfStar ? 'text-on-tertiary-container' : 'text-surface-container-highest')}`}>★</span>
          ))}
        </div>
        <span class="label-text text-on-surface-variant">{rating}/5</span>
        {price && <span class="label-text text-on-surface font-bold ml-auto">{price}</span>}
      </div>

      <!-- Pros & Cons -->
      {(pros.length > 0 || cons.length > 0) && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          {pros.length > 0 && (
            <ul class="space-y-1.5">
              {pros.slice(0, 3).map((pro) => (
                <li class="flex items-start gap-2 text-sm font-body">
                  <span class="material-symbols-outlined text-secondary text-sm mt-0.5">check</span>
                  <span class="text-on-surface-variant">{pro}</span>
                </li>
              ))}
            </ul>
          )}
          {cons.length > 0 && (
            <ul class="space-y-1.5">
              {cons.map((con) => (
                <li class="flex items-start gap-2 text-sm font-body">
                  <span class="material-symbols-outlined text-on-tertiary-container text-sm mt-0.5">close</span>
                  <span class="text-on-surface-variant">{con}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}

      {verdict && (
        <p class="text-on-surface-variant text-sm font-body italic mb-5">{verdict}</p>
      )}

      <!-- CTAs -->
      <div class="flex flex-wrap items-center gap-4">
        <a
          href={`/go/${affiliateSlug}/`}
          class="btn-primary text-xs no-underline inline-flex items-center gap-3"
          target="_blank"
          rel="nofollow sponsored noopener"
        >
          Check Price on Amazon
          <span class="material-symbols-outlined text-sm">open_in_new</span>
        </a>
        {slug && (
          <a href={`/reviews/${slug}/`} class="text-secondary label-text font-bold no-underline hover:underline underline-offset-4">
            Read Full Review
          </a>
        )}
      </div>
    </div>
  </div>
</div>
