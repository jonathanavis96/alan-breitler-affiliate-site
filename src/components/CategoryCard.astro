---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon = '📦' } = Astro.props;
---

<a href={href} class="card group block no-underline hover:border-primary/30">
  <div class="text-3xl mb-3">{icon}</div>
  <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-gray-600">{description}</p>
  <span class="inline-flex items-center text-sm font-medium text-primary mt-3">
    View picks
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </span>
</a>
