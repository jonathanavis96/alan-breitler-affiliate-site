---
interface Props {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
  class?: string;
  narrow?: boolean;
  id?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  class: className = '',
  narrow = false,
  id,
} = Astro.props;
---

<section class:list={['py-16 md:py-24', className]} id={id}>
  <div class:list={[narrow ? 'container-narrow' : 'container-wide']}>
    {(title || subtitle || eyebrow) && (
      <div class="mb-12">
        {eyebrow && <span class="label-text text-secondary font-bold mb-4 block">{eyebrow}</span>}
        {title && <h2 class="font-headline italic text-3xl md:text-4xl text-on-surface mb-4">{title}</h2>}
        {subtitle && <p class="text-on-surface-variant max-w-2xl font-body text-lg">{subtitle}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
