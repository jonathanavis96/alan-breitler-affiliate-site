---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  narrow?: boolean;
  id?: string;
}

const {
  title,
  subtitle,
  class: className = '',
  narrow = false,
  id,
} = Astro.props;
---

<section class:list={['py-12 md:py-16', className]} id={id}>
  <div class:list={[narrow ? 'container-narrow' : 'container-wide']}>
    {(title || subtitle) && (
      <div class="text-center mb-10">
        {title && <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">{title}</h2>}
        {subtitle && <p class="text-gray-600 max-w-2xl mx-auto">{subtitle}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
